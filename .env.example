NODE_ENV=development
PORT=3000

# ─── CORS ──────────────────────────────────────────────────────────────
# Comma-separated allow-list of origins for the admin web + mobile.
# Empty in dev ⇒ reflect any origin. In prod set to something like:
#   CORS_ORIGINS=https://admin.lmnica.com,https://staging.admin.lmnica.com
CORS_ORIGINS=

# ─── Database ──────────────────────────────────────────────────────────
# Option A (preferred on Railway / any hosted Postgres):
#   DATABASE_URL=postgres://user:pass@host:5432/dbname
# Option B (local dev via docker-compose.yml Postgres):
DB_HOST=localhost
DB_PORT=5435
DB_USER=loteria
DB_PASSWORD=loteria
DB_NAME=loteria

# ─── Auth ──────────────────────────────────────────────────────────────
JWT_SECRET=change-me-please-super-secret-key
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=30d
